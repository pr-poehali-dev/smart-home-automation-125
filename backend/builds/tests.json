{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET без токена",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    },
    {
      "name": "POST без токена",
      "method": "POST",
      "path": "/",
      "body": {"site_url": "https://example.com", "app_name": "Test"},
      "expectedStatus": 401
    },
    {
      "name": "PUT без токена",
      "method": "PUT",
      "path": "/?id=1",
      "body": {"site_url": "https://example.com", "app_name": "Test"},
      "expectedStatus": 401
    },
    {
      "name": "Callback без токена сервера",
      "method": "POST",
      "path": "/?action=callback",
      "body": {"build_id": 123, "status": "ready"},
      "expectedStatus": 403
    },
    {
      "name": "Download без токена",
      "method": "GET",
      "path": "/?action=download&id=1",
      "expectedStatus": 401
    }
  ]
}